{
  "functions": {
    "api/*.py": {
      "runtime": "@vercel/python@4.3.1",
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/trackrecord",
      "schedule": "0 21 * * 1-5"
    },
    {
      "path": "/api/cron/cb-snapshot",
      "schedule": "0 6 1 * *"
    },
    {
      "path": "/api/cron/execution",
      "schedule": "5 21 * * 1-5"
    },
    {
      "path": "/api/cron/news",
      "schedule": "0 7 * * *"
    }
  ]
}
