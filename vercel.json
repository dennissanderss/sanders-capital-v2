{
  "functions": {
    "api/*.py": {
      "runtime": "@vercel/python@4.3.1",
      "maxDuration": 30
    },
    "src/app/api/news/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/*/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/briefing-v2/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/news",
      "schedule": "15 6 * * *"
    },
    {
      "path": "/api/cron/trackrecord",
      "schedule": "0 6 * * 1-5"
    },
    {
      "path": "/api/cron/execution",
      "schedule": "30 6 * * 1-5"
    },
    {
      "path": "/api/cron/cb-snapshot",
      "schedule": "0 6 1 * *"
    }
  ]
}
